# Planner Service Configuration

# Scheduler Configuration
# URL of the scheduler service for instance registration
# If not provided, must be specified in API requests
SCHEDULER_URL=http://localhost:8100

# Instance Deployment Configuration
# Timeout for HTTP requests to instance services (in seconds)
INSTANCE_TIMEOUT=30

# Maximum number of retry attempts for failed instance API calls
INSTANCE_MAX_RETRIES=3

# Initial delay between retries (in seconds)
# Uses exponential backoff: delay = INSTANCE_RETRY_DELAY * (2 ^ attempt)
INSTANCE_RETRY_DELAY=1.0

# Planner Service Configuration
# Host to bind the planner service to
PLANNER_HOST=0.0.0.0

# Port to run the planner service on
PLANNER_PORT=8000
