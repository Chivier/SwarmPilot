# Predictor Service Configuration Example
# Copy this file to 'predictor.toml' and customize as needed.
#
# Configuration priority (highest to lowest):
# 1. Command-line arguments
# 2. Environment variables (PREDICTOR_* prefix)
# 3. Configuration file (this file)
# 4. Default values

[predictor]

# ============================================================================
# Server Settings
# ============================================================================

# Host to bind the server to
# Default: "0.0.0.0" (all interfaces)
# Production: Consider "127.0.0.1" if behind a reverse proxy
host = "0.0.0.0"

# Port to bind the server to
# Default: 8000
port = 8000

# Enable auto-reload for development
# WARNING: Do not use in production!
# Default: false
reload = false

# Number of worker processes for production deployment
# Ignored when reload=true
# Recommendation: Number of CPU cores
# Default: 1
workers = 1

# ============================================================================
# Storage Settings
# ============================================================================

# Directory to store trained models
# This directory will be created if it doesn't exist
# Default: "models"
storage_dir = "models"

# ============================================================================
# Logging Settings
# ============================================================================

# Logging level
# Options: "critical", "error", "warning", "info", "debug"
# Default: "info"
log_level = "info"

# ============================================================================
# Application Metadata
# ============================================================================

# Application name (displayed in API docs and CLI)
# Default: "Runtime Predictor Service"
app_name = "Runtime Predictor Service"

# Application version
# Default: "0.1.0"
app_version = "0.1.0"

# ============================================================================
# Example: Development Configuration
# ============================================================================
# Uncomment and modify for local development:
#
# host = "127.0.0.1"
# port = 8000
# reload = true
# storage_dir = "./dev_models"
# log_level = "debug"

# ============================================================================
# Example: Production Configuration
# ============================================================================
# Uncomment and modify for production deployment:
#
# host = "0.0.0.0"
# port = 8000
# reload = false
# workers = 4
# storage_dir = "/var/lib/predictor/models"
# log_level = "warning"

# ============================================================================
# Environment Variables
# ============================================================================
# You can also set these values via environment variables:
#
# export PREDICTOR_HOST="0.0.0.0"
# export PREDICTOR_PORT=8000
# export PREDICTOR_RELOAD=false
# export PREDICTOR_WORKERS=4
# export PREDICTOR_STORAGE_DIR="/path/to/models"
# export PREDICTOR_LOG_LEVEL="info"
# export PREDICTOR_APP_NAME="My Predictor Service"
# export PREDICTOR_APP_VERSION="0.1.0"
