# Instance Service Configuration Example
# Copy this file to .env and customize as needed

# ==================== Instance Configuration ====================
# Unique identifier for this instance
INSTANCE_ID=instance-default

# Port for the instance API server (model containers use INSTANCE_PORT + 1000)
INSTANCE_PORT=5000

# ==================== Logging Configuration ====================
# Logging level: TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL
INSTANCE_LOG_LEVEL=INFO

# Directory for log files
INSTANCE_LOG_DIR=logs

# Enable JSON structured logging (useful for log aggregation)
INSTANCE_ENABLE_JSON_LOGS=false

# ==================== Task Queue Configuration ====================
# Maximum number of tasks in queue
MAX_QUEUE_SIZE=100

# ==================== Docker Configuration ====================
# Docker network name for model containers
DOCKER_NETWORK=instance_network

# ==================== Health Check Configuration ====================
# Health check interval in seconds
HEALTH_CHECK_INTERVAL=10

# Health check timeout in seconds
HEALTH_CHECK_TIMEOUT=30

# ==================== Platform Information Overrides ====================
# Override auto-detected platform information
# Useful for testing, multi-environment setups, or custom reporting

# Override OS name (e.g., "Linux", "Darwin", "Windows")
# INSTANCE_PLATFORM_SOFTWARE_NAME=Linux

# Override OS version (e.g., "5.15.0-151-generic", "22.04")
# INSTANCE_PLATFORM_SOFTWARE_VERSION=5.15.0-151-generic

# Override hardware name (e.g., "NVIDIA GeForce RTX 4090", "CPU")
# INSTANCE_PLATFORM_HARDWARE_NAME=NVIDIA GeForce RTX 4090

# ==================== Scheduler Integration ====================
# (Optional) Configure if using with a scheduler service
# SCHEDULER_URL=http://localhost:5001
# INSTANCE_ENDPOINT=http://localhost:5000
